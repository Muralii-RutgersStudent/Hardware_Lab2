enclave {
    from "sgx_tstdc.edl" import *;
    trusted {
        public void ecall_deposit(int amount);
        public void ecall_pay(int amount);
        public void ecall_view_balance();
        public void ecall_view_transactions();
    };
    untrusted {
        void ocall_print_string([in, string] const char *str);
        void ocall_print_balance(int balance);
        void ocall_print_transaction([in, string] const char *type, int amount);
    };
};
